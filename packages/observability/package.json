{
  "name": "@monorepo-template/observability",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": [
    "./dist/nest/index.mjs"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser/index.d.mts",
      "import": "./dist/browser/index.mjs"
    },
    "./nest": {
      "types": "./dist/nest/index.d.mts",
      "import": "./dist/nest/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@monorepo-template/env": "workspace:*",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.30.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=11.0.0",
    "@nestjs/core": ">=11.0.0",
    "@nestjs/terminus": ">=10.0.0",
    "fastify": ">=5.0.0",
    "nestjs-pino": ">=4.0.0",
    "pino-http": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "@nestjs/terminus": {
      "optional": true
    },
    "nestjs-pino": {
      "optional": true
    },
    "pino-http": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@monorepo-template/linter": "workspace:*",
    "@monorepo-template/typescript-config": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@types/node": "catalog:",
    "fastify": "^5.0.0",
    "nestjs-pino": "^4.2.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
