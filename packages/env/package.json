{
  "name": "@monorepo-template/env",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./node": {
      "types": "./dist/node.d.mts",
      "import": "./dist/node.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "rstest run --passWithNoTests",
    "test:watch": "rstest watch",
    "test:coverage": "rstest run --coverage --coverage.reporters=lcov --coverage.reporters=text --passWithNoTests"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@monorepo-template/linter": "workspace:*",
    "@monorepo-template/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "^0.10.3",

    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
