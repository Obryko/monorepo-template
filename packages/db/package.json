{
  "name": "@monorepo-template/db",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "rstest run --passWithNoTests",
    "test:watch": "rstest watch",
    "test:coverage": "rstest run --coverage --coverage.reporters=lcov --coverage.reporters=text --passWithNoTests"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@monorepo-template/linter": "workspace:*",
    "@monorepo-template/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",

    "drizzle-kit": "^0.31.0",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
