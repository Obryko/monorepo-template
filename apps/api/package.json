{
  "name": "@monorepo-template/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "rstest run --config rstest.unit.config.ts --passWithNoTests",
    "test:coverage": "rstest run --config rstest.unit.config.ts --coverage --coverage.reporters=lcov --coverage.reporters=text --passWithNoTests",
    "test:unit": "rstest run --config rstest.unit.config.ts --passWithNoTests",
    "test:unit:watch": "rstest watch --config rstest.unit.config.ts",
    "test:e2e": "rstest run --config rstest.e2e.config.ts --passWithNoTests",
    "test:e2e:watch": "rstest watch --config rstest.e2e.config.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@monorepo-template/contracts": "workspace:*",
    "@monorepo-template/db": "workspace:*",
    "@monorepo-template/env": "workspace:*",
    "@monorepo-template/observability": "workspace:*",
    "@monorepo-template/sentry": "workspace:*",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "fastify": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "nestjs-pino": "^4.2.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@monorepo-template/linter": "workspace:*",
    "@monorepo-template/typescript-config": "workspace:*",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "catalog:"
  }
}
