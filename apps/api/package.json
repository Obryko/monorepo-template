{
  "name": "@monorepo-template/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.unit.config.ts --passWithNoTests",
    "test:unit": "vitest run --config vitest.unit.config.ts --passWithNoTests",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts --passWithNoTests",
    "test:e2e:watch": "vitest --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@monorepo-template/contracts": "workspace:*",
    "@monorepo-template/env": "workspace:*",
    "@monorepo-template/observability": "workspace:*",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "nestjs-pino": "^4.2.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod-openapi": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@monorepo-template/linter": "workspace:*",
    "@monorepo-template/typescript-config": "workspace:*",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@swc/core": "^1.15.40",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "typescript": "catalog:",
    "unplugin-swc": "^1.5.9",
    "vitest": "catalog:"
  }
}
