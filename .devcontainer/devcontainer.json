{
  "name": "monorepo-template",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-24",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [3000, 3001, 3002, 5432, 6006],
  "portsAttributes": {
    "3000": { "label": "Web" },
    "3001": { "label": "API" },
    "3002": { "label": "Remote MF" },
    "5432": { "label": "Postgres" },
    "6006": { "label": "Storybook" }
  },
  "postCreateCommand": "corepack enable && corepack prepare pnpm@latest --activate && pnpm install && cp apps/api/.env.example apps/api/.env && cp apps/web/.env.example apps/web/.env",
  "postStartCommand": "docker compose up -d postgres",
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "editor.defaultFormatter": "biomejs.biome",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.biome": "explicit"
        },
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  }
}
